# Required: Owner private key (0x-prefixed, 64 hex chars)
# This key controls your smart account. Never share it.
AZETH_PRIVATE_KEY=0x

# Chain: baseSepolia (default, free testnet) | base | ethereumSepolia | ethereum
AZETH_CHAIN=baseSepolia

# Optional: Custom RPC endpoint (uses public default if empty)
# AZETH_RPC_URL=

# Optional: Guardian key for co-signing high-value operations
# AZETH_GUARDIAN_KEY=0x
# AZETH_GUARDIAN_AUTO_SIGN=true

# Optional: Payment recipient address (defaults to your smart account)
# X402_PAY_TO=0x
